/* ~/.config/waybar/style.css */

/* ---------------------------------------- */
/* -----       TASK BAR DESIGN        ----- */
/* ---------------------------------------- */
* {
    font-family: "JetBrainsMono Nerd Font", "Noto Sans", sans-serif;
    min-height: 0;
}

window#waybar {
    background-color: rgba(28, 28, 38, 0.92);
    margin: 10px 30px;
    padding: 3px 6px;
    color: #cad3f5;
    border-radius: 18px;
    border: 1px solid rgba(202, 211, 245, 0.08);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

/* ---------------------------------------- */
/* -----           TOOLTIP            ----- */
/* ---------------------------------------- */
/* TODO: possible to hide the black square corners behind the rounded corners?*/
tooltip {
    background-color: rgba(17, 17, 27, 0.92);
    border: 1px solid rgba(138, 173, 244, 0.3);
    border-radius: 12px;
    padding: 10px 14px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
}

#tooltip {
    background-color: transparent;
    border: none;
    border-radius: 12px;
    padding: 0;
    font-family: "JetBrainsMono Nerd Font", "Noto Sans", sans-serif;
    font-size: 14px;
}

#tooltip label {
    color: #cad3f5;
    background-color: transparent;
    border: none;
    padding: 0;
}

/* ---------------------------------------- */
/* -----          WORKSPACES          ----- */
/* ---------------------------------------- */
#workspaces {
    background-color: rgba(30, 41, 59, 0.55);
    border-radius: 5px;
    border: 1px solid rgba(202, 211, 245, 0.07);
    padding: 0 6px;
    margin: 5px 4px;
}

/* Default: every workspace is a small quiet dot, no number shown */
#workspaces button {
    background-color: rgba(202, 211, 245, 0.18);
    color: transparent;
    font-size: 0;
    min-width: 8px;
    min-height: 4px;
    padding: 0;
    margin: 5px 4px;
    border-radius: 50px;
    border: none;
    transition: all 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
}

#workspaces button:hover {
    background-color: rgba(202, 211, 245, 0.4);
}

/* Workspaces with no windows fade further so empty desktops
   don't compete visually with where the work actually is */
#workspaces button.empty {
    /*background-color: rgba(202, 211, 245, 0.12);*/
    background-color: rgba(202, 255, 255, 0.42);
}

#workspaces button.empty:hover {
    background-color: rgba(202, 211, 245, 0.3);
}

/* Active workspace morphs from a dot into a labeled pill */
#workspaces button.active {
    min-width: 24px;
    min-height: 22px;
    padding: 0 9px;
    font-size: 17px;
    font-weight: 700;
    color: #1c1c26;
    background-color: #7287fd;
}

#workspaces button.urgent {
    background-color: #ed8796;
}

/* ---------------------------------------- */
/* -----       GENERAL MODULES        ----- */
/* ---------------------------------------- */
#custom-menu,
/*#window,*/
#custom-weather,
#mpris,
#cpu,
#memory,
#network,
#pulseaudio,
#custom-cliphist,
#tray,
#language,
#clock,
#custom-power {
    border: 1px solid transparent;
    font-weight: bold;
    transition: all 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    background-color: rgba(0, 0, 0, 0);
    color: #cad3f5;
}

/*#window:hover,*/
#custom-weather:hover,
#cpu:hover,
#memory:hover,
#network:hover,
#pulseaudio:hover,
#custom-cliphist:hover,
#language:hover,
#clock:hover {
    background-color: rgba(114, 135, 253, 0.12);
    border-radius: 10px;
    border: 1px solid rgba(114, 135, 253, 0.28);
    box-shadow:
        0 0 14px rgba(114, 135, 253, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

/* ---------------------------------------- */
/* -----         LEFT MODULES         ----- */
/* ---------------------------------------- */
#custom-menu {
    color: #1793d1;
    padding: 2px 23px 2px 15px;
    margin: 2px 0px 2px 4px;
    transition: all 0.2s;
    font-size: 27px;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    border-right: 0px;
}

#custom-menu:hover {
    color: #ffffff;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    border-right: 0px;
}

#custom-weather {
    font-size: 16px;
    padding: 2px 10px 2px 5px;
    margin: 5px 2px;
}

/* ---------------------------------------- */
/* -----        MIDDLE MODULES        ----- */
/* ---------------------------------------- */
/*FIXME: stop icons from jumping*/
#taskbar {
    padding: 1px 6px;
    margin: 2px 3px;
    background-color: rgba(55, 58, 82, 0.35);
    box-shadow:
        0 4px 16px rgba(0, 0, 0, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    border-radius: 14px;
    border: 1px solid rgba(202, 211, 245, 0.07);
}

#taskbar button {
    padding: 2px 5px;
    margin: 3px 2px 1px 2px;
    border: 1px solid transparent;
    border-radius: 10px;
    transition: all 0.2s ease;
}

#taskbar button:hover {
    background-color: rgba(147, 153, 178, 0.22);
    border-color: rgba(202, 211, 245, 0.12);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    margin-top: 1px;
    margin-bottom: 3px;
}

#taskbar button.active {
    background-color: rgba(114, 135, 253, 0.32);
    border-color: rgba(114, 135, 253, 0.35);
    box-shadow:
        0 0 14px rgba(114, 135, 253, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    border-bottom: 2px solid rgba(114, 135, 253, 0.75);
}

#taskbar button.active:hover {
    margin-top: 1px;
    margin-bottom: 3px;
    box-shadow:
        0 4px 18px rgba(114, 135, 253, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

#taskbar image {
    margin: 0 2px;
}

/* ---------------------------------------- */
/* -----        RIGHT MODULES         ----- */
/* ---------------------------------------- */
/* Music module  */
#mpris {
    background-color: rgba(91, 96, 120, 0.3);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    border: 2px solid rgba(202, 211, 245, 0.5);
    border-radius: 12px;
    color: #cad3f5;
    padding: 2px 12px 2px 8px;
    margin: 5px 2px;
    font-size: 15px;
    font-weight: bold;
}

#mpris:hover {
    background-color: rgba(147, 153, 178, 0.3);
    border-radius: 12px;
}

/*#battery {
    border-bottom: 2px solid #a6da95;
}*/

/*CPU & Memory */
#cpu,
#memory {
    font-size: 16px;
    padding: 2px 10px 2px 5px;
    margin: 5px 2px;
}

/*#temperature.critical {
    background-color: #ed8796;
    color: #24273a;
    font-size: 15px;
    border-bottom: 2px solid #ed8796;
}*/

#network {
    font-size: 18px;
    padding: 2px 11px 2px 6px;
    margin: 5px 2px;
}

/* Volume control */
#pulseaudio {
    background-color: rgba(0, 0, 0, 0);
    color: #cad3f5;
    font-size: 16px;
    padding: 2px 10px 2px 5px;
    margin: 5px 2px;
}
#pulseaudio.muted {
    color: #6e738d;
    font-size: 18px;
    padding: 2px 10px 2px 5px;
    margin: 5px 2px;
}

#custom-cliphist {
    font-size: 16px;
    padding: 2px 2px 2px 7px;
    margin: 5px 2px;
}

#tray {
    margin: 0;
    padding: 2px 5px 2px 5px;
    font-size: 15px;
    margin: 1px 2px;
}

#language {
    font-size: 16px;
    padding: 2px 4px 2px 5px;
    margin: 5px 2px;
}

/* TODO: why align to right not works */
#clock {
    font-size: 12px;
    padding: 2px 3px 2px 5px;
    margin: 3px 2px;
}

#custom-power {
    min-width: 20px;
    padding: 2px 10px 2px 7px;
    font-size: 18px;
    margin: 3px 10px 3px 3px;
    border-radius: 50px;
}

#custom-power:hover {
    color: #ed8796;
    border-radius: 50px;
}
