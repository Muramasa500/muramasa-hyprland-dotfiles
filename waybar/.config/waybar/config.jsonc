  // ============================================================
  // ======                  LEFT MODULES                  ======
  // ============================================================
  "custom/menu": {
    "format": "´îâ",
    "tooltip": true,
    "tooltip-format": "Application Menu",
    "on-click": "rofi -show drun -display-drun ''",
    "return-type": "json",
  },

  "custom/weather": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/weather-app/weather.sh",
    "interval": 600,
    "tooltip": true,
    "on-click": "xdg-open https://www.smhi.se",
  },

  // TODO: Changing layout not working yet
  // "custom/layout": {
  //   "format": "{}",
  //   "return-type": "json",
  //   "exec": "~/.config/waybar/hypr_layout.sh",
  //   "interval": 5,
  //   "tooltip": true,
  //   "on-click": "~/.config/waybar/toggle_layout.sh",
  //   "restart-interval": 1,
  // },

  // ============================================================
  // ======                MIDDLE MODULES                  ======
  // ============================================================

  // ============================================================
  // ======                 RIGHT MODULES                  ======
  // ============================================================
  // TODO: possible to let media playing showing album art?
  // media playing
  "mpris": {
    "format": "´üï {artist} - {title}",
    "format-no-player": "´üì No Music",
    "format-stopped": "No Music",
    "format-paused": "´üî {artist} - {title}",
    // "tooltip-format": "{title} by {artist}",
    "tooltip-format": "Title: {title}\nArtist: {artist}\nAlbum: {album}",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    //"max-length": 15,
    "max-length": 35,
  },

  // Show CPU usage
  "cpu": { "format": "{usage}% ´ïø" },

  // Show memory usage
  "memory": { "format": "{}% ´âë" },

  // TODO: is it possible to show several network interfaces?
  "network": {
    "interface": "enp0s31f6",
    "format": "¾░êÇ",
    "format-wifi": "{essid} ({signalStrength}%) ´ç½",
    "format-ethernet": "¾░êÇ",
    "format-disconnected": "", //An empty format will hide the module.
    "tooltip-format": "{bandwidthUpBytes}/{bandwidthDownBytes}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ´ç½",
    "tooltip-format-ethernet": "{ifname}: {bandwidthUpBytes}/{bandwidthDownBytes}",
    "tooltip-format-disconnected": "¾░êé",
    "max-length": 40,
    "interval": 1,
  },

  // TODO: want to add a drop down menu (floating) of pavucontrol if possible
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´èö",
    "format-muted": "¾░ûü",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "¯î¡",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "¯╗¿¯î¡",
      /* "headphone": "´ÇÑ",
        "hands-free": "´ûÉ",*/
      "headset": "´ûÉ",
      "default": ["´Çº", "´Ç¿"],
    },
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
  },

  "custom/cliphist": {
    "format": "´â¬ ",
    "tooltip": true,
    "tooltip-format": "Clip history",
    "on-click": "~/.config/waybar/rofi-cliphist.sh",
    // "on-click-right": "cliphist delete",
    "return-type": "json",
    "interval": "once",
  },

  "tray": {
    "icon-size": 21,
    "spacing": 10,
    "max-width": 0,
    "rotate": 0,
    /*"show-passive-items": true, */
  },

  // TODO: fix tooltip
  // Change language
  "hyprland/language": {
    "format": "´ä£  {}",
    "format-en": "EN",
    "format-sv": "SE",
    "format-en-tootip": "English (US)",
    "format-sv-tootip": "Swedish",
    "on-click": "hyprctl switchxkblayout current next",
  },

  // FIXME: battery function not working, and can not get it to show battery for both mouse and keyboard, as they seems to share USB dongle
  // "battery": {
  //   "bat": ["battery_hidpp_battery_0"],
  //   "format": "{capacity}% {icon}",
  //   "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
  //   "format-charging": "{capacity}% ´ùº",
  //   "states": {
  //     "good": 95,
  //     "warning": 30,
  //     "critical": 15,
  //   },
  //   "tooltip": true,
  //   "tooltip-format": "MX Keys: {capacity}% ({status})",
  // },

  "clock": {
    // "format": "{:%H:%M}",
    "format": "{:%H:%M\n%Y/%m/%d}",
    "format-alt": "{:%A\n%B %d, %Y} ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-right": "mode",
      // "on-scroll-up": "tz_up",
      // "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },

  // Power menu, turn off, restart, and so on
  "custom/power": {
    "format": "ÔÅ╗",
    "tooltip-format": "Power Menu",
    "on-click": "~/.config/waybar/rofi-power-menu.sh",
  },
}
