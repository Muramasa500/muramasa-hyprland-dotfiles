{
  // ============================================================
  // ======                   LAYOUT                       ======
  // ============================================================

  "layer": "top",
  "position": "top",
  "height": 45,
  "spacing": 2,

  "margin-top": 0,
  "margin-bottom": 0,

  // "margin-top": 4,
  // "margin-left": 15,
  // "margin-right": 15,
  // "margin-bottom": 0,

  "modules-left": [
    "custom/menu",
    "hyprland/workspaces",
    "custom/weather",
    "custom/layout",
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "mpris",
    "cpu",
    "memory",
    "network",
    "battery",
    "pulseaudio",
    "custom/cliphist",
    "tray",
    "hyprland/language",
    "clock",
    "custom/power",
  ],

