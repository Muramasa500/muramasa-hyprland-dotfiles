/* ~/.config/waybar/style.css */

/* ---------------------------------------- */
/* -----       TASK BAR DESIGN        ----- */
/* ---------------------------------------- */
* {
    font-family: "JetBrainsMono Nerd Font", "Noto Sans", sans-serif;
    min-height: 0;
}

window#waybar {
    background-color: rgba(28, 28, 38, 0.92);
    margin: 10px 30px;
    padding: 3px 6px;
    color: #cad3f5;
    border-radius: 14px;
    border: 1px solid rgba(202, 211, 245, 0.08);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 0 20px rgba(114, 135, 253, 0.08);
}

/* ---------------------------------------- */
/* -----           TOOLTIP            ----- */
/* ---------------------------------------- */
tooltip {
    background-color: rgba(35, 35, 48, 0.96);
    border: 1px solid rgba(138, 173, 244, 0.4);
    border-radius: 10px;
    padding: 12px 16px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.45);
}

#tooltip {
    background-color: transparent;
    border: none;
    border-radius: 10px;
    padding: 0;
    font-family: "JetBrainsMono Nerd Font", "Noto Sans", sans-serif;
    font-size: 14px;
}

#tooltip label {
    color: #cad3f5;
    background-color: transparent;
    border: none;
    padding: 0;
}

/* ---------------------------------------- */
/* -----          WORKSPACES          ----- */
/* ---------------------------------------- */
#workspaces {
    background-color: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    margin: 2px 2px;
}

#workspaces button {
    background-color: rgba(46, 56, 98, 0.45);
    color: #cad3f5;
    font-size: 19px;
    font-weight: bold;
    padding: 2px 15px 2px 5px;
    margin: 1px 0px 1px 0px;
    border-radius: 0;
    transition: all 0.2s ease;
    border-right: 1px solid rgba(0, 0, 0, 0.3);
    border-left: 1px solid rgba(0, 0, 0, 0.3);
    border-bottom: 4px solid rgba(55, 55, 55, 0.3);
    min-width: 6px;
}

/* first button of each 3-group → left rounded */
#workspaces button:nth-child(3n + 1) {
    border-top-left-radius: 8px;
    border-bottom-left-radius: 8px;
}

/* last button of each 3-group → right rounded + gap */
#workspaces button:nth-child(3n) {
    margin-right: 12px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
}

/* ======================================== */
/* -----          ACTIVE COLORS       ----- */
/* ======================================== */
#workspaces button.active {
    font-weight: 700;
    color: #cad3f5;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 1;
    background-color: rgba(114, 135, 253, 0.4);
}

/* --- Monitor 1 (WS 1-3) --- */
#workspaces button.active:nth-child(1) {
    border-bottom: 4px solid rgb(254, 100, 11);
    box-shadow: 0 0 10px rgba(254, 100, 11, 0.4);
}
#workspaces button.active:nth-child(2) {
    border-bottom: 4px solid rgb(220, 138, 120);
    box-shadow: 0 0 10px rgba(220, 138, 120, 0.4);
}
#workspaces button.active:nth-child(3) {
    border-bottom: 4px solid rgb(136, 57, 239);
    box-shadow: 0 0 10px rgba(136, 57, 239, 0.4);
}

/* --- Monitor 2 (WS 4-6) --- */
#workspaces button.active:nth-child(4) {
    border-bottom: 4px solid rgb(64, 160, 43);
    box-shadow: 0 0 10px rgba(64, 160, 43, 0.4);
}
#workspaces button.active:nth-child(5) {
    border-bottom: 4px solid rgb(230, 69, 83);
    box-shadow: 0 0 10px rgba(230, 69, 83, 0.4);
}
#workspaces button.active:nth-child(6) {
    border-bottom: 4px solid rgb(136, 57, 239);
    box-shadow: 0 0 10px rgba(136, 57, 239, 0.4);
}

/* --- Monitor 3 (WS 7-9) --- */
#workspaces button.active:nth-child(7) {
    border-bottom: 4px solid rgb(234, 118, 203);
    box-shadow: 0 0 10px rgba(234, 118, 203, 0.4);
}
#workspaces button.active:nth-child(8) {
    border-bottom: 4px solid rgb(114, 135, 253);
    box-shadow: 0 0 10px rgba(114, 135, 253, 0.4);
}
#workspaces button.active:nth-child(9) {
    border-bottom: 4px solid rgb(210, 15, 57);
    box-shadow: 0 0 10px rgba(210, 15, 57, 0.4);
}
#workspaces button.active:nth-child(n + 10) {
    border-bottom: 4px solid rgb(32, 159, 181);
    box-shadow: 0 0 10px rgba(32, 159, 181, 0.4);
}

/* ---------------------------------------- */
/* -----       GENERAL MODULES        ----- */
/* ---------------------------------------- */
#custom-menu,
#custom-weather,
#mpris,
#cpu,
#memory,
#network,
#pulseaudio,
#custom-cliphist,
#tray,
#language,
#clock,
#custom-power {
    border: 1px solid transparent;
    font-weight: bold;
    transition: all 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    background-color: rgba(0, 0, 0, 0);
    color: #cad3f5;
}

#custom-menu:hover,
#custom-weather:hover,
#cpu:hover,
#memory:hover,
#network:hover,
#pulseaudio:hover,
#custom-cliphist:hover,
#language:hover,
#clock:hover,
#custom-power:hover {
    background-color: rgba(114, 135, 253, 0.15);
    border-radius: 8px;
    border: 1px solid rgba(114, 135, 253, 0.25);
    box-shadow: 0 0 12px rgba(114, 135, 253, 0.12);
}

#custom-menu:hover,
#custom-power:hover {
    background-color: rgba(114, 135, 253, 0.25);
    border: 1px solid rgba(114, 135, 253, 0.35);
    color: #ffffff;
}

/* ---------------------------------------- */
/* -----         LEFT MODULES         ----- */
/* ---------------------------------------- */
#custom-menu {
    color: #1793d1;
    padding: 2px 23px 2px 15px;
    margin: 2px 0px 2px 4px;
    transition: all 0.2s;
    font-size: 27px;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    border-right: 0px;
}

#custom-menu:hover {
    color: #ffffff;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    border-right: 0px;
}

#custom-weather {
    font-size: 16px;
    padding: 2px 10px 2px 5px;
    margin: 5px 2px;
}

/* ---------------------------------------- */
/* -----        MIDDLE MODULES        ----- */
/* ---------------------------------------- */
#taskbar {
    padding: 1px 6px;
    margin: 2px 3px;
    background-color: rgba(55, 58, 82, 0.35);
    box-shadow:
        0 4px 16px rgba(0, 0, 0, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    border-radius: 14px;
    border: 1px solid rgba(202, 211, 245, 0.07);
}

#taskbar button {
    padding: 2px 5px;
    margin: 3px 2px 1px 2px;
    border: 1px solid transparent;
    border-radius: 10px;
    transition: all 0.2s ease;
}

#taskbar button:hover {
    background-color: rgba(147, 153, 178, 0.22);
    border-color: rgba(202, 211, 245, 0.12);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
}

#taskbar button.active {
    background-color: rgba(114, 135, 253, 0.32);
    border-color: rgba(114, 135, 253, 0.35);
    box-shadow:
        0 0 14px rgba(114, 135, 253, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    border-bottom: 2px solid rgba(114, 135, 253, 0.75);
}

#taskbar button.active:hover {
    box-shadow:
        0 4px 18px rgba(114, 135, 253, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

#taskbar image {
    margin: 0 2px;
}

/* ---------------------------------------- */
/* -----        RIGHT MODULES         ----- */
/* ---------------------------------------- */
/* Music module */
#mpris {
    background-color: rgba(91, 96, 120, 0.3);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    border: 2px solid rgba(202, 211, 245, 0.5);
    border-radius: 12px;
    color: #cad3f5;
    padding: 2px 12px 2px 8px;
    margin: 5px 2px;
    font-size: 15px;
    font-weight: bold;
}

#mpris:hover {
    background-color: rgba(147, 153, 178, 0.3);
    border-radius: 12px;
}

/* CPU & Memory */
#cpu,
#memory {
    font-size: 16px;
    padding: 3px 12px;
    margin: 4px 2px;
}

/* Network */
#network {
    font-size: 18px;
    padding: 3px 12px;
    margin: 4px 2px;
}

/* Volume control */
#pulseaudio {
    background-color: rgba(0, 0, 0, 0);
    color: #cad3f5;
    font-size: 16px;
    padding: 3px 12px;
    margin: 4px 2px;
}

#pulseaudio.muted {
    color: #6e738d;
    font-size: 18px;
    padding: 3px 12px;
    margin: 4px 2px;
}

#custom-cliphist {
    font-size: 16px;
    padding: 3px 10px;
    margin: 4px 2px;
}

#tray {
    padding: 2px 5px;
    font-size: 15px;
    margin: 4px 2px;
}

#language {
    font-size: 16px;
    padding: 3px 10px;
    margin: 4px 2px;
}

#clock {
    font-size: 12px;
    padding: 3px 10px;
    margin: 4px 2px;
}

#custom-power {
    min-width: 20px;
    padding: 3px 10px;
    font-size: 18px;
    margin: 4px 10px 4px 3px;
    border-radius: 50px;
}

#custom-power:hover {
    color: #ed8796;
    border-radius: 50px;
}
