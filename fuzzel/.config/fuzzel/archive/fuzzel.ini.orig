mkdir -p ~/.config/fuzzel
cat > ~/.config/fuzzel/fuzzel.ini <<EOF
[colors]
background=24273aff   # Base (Background) - Alpha ff = fully opaque
text=cad3f5ff         # Text Color
match=8aadf4ff        # Matching text (Blue)
selection=494d64ff    # Selected item background (Surface0)
selection-text=cad3f5ff # Selected text color
selection-match=eed49fff # Matched text in selection (Yellow highlight)
border=8aadf4ff       # Border color (Blue)
placeholder=a5adceff  # Placeholder text (Subtext1)

[border]
width=2
radius=12

[dmenu]
mode=text             # Use text mode for simple lists
exit-immediately-if-empty=yes

[input]
prompt="Power Menu ❯ "
font=JetBrainsMono Nerd Font:size=14
line-height=18
EOF
